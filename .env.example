# API configuration
API_PORT=3000
API_PREFIX=/api/v1

# Portal (Angular) base URL — used for OAuth redirects back to /app/connections
PORTAL_URL=http://localhost:4200

# Swagger API documentation
SWAGGER_ENABLE=1

# Database configuration
DATABASE_URL=mongodb://localhost:27017/nestjs

# JWT configuration
JWT_SECRET=ThisMustBeChanged
JWT_ISSUER=IssuerApplication
PUBLIC_FRONTEND_API_KEY=ThisMustBeChanged

# Access to the health route
HEALTH_TOKEN=ThisMustBeChanged

# Domain-related configuration
PASSENGERS_ALLOWED=yes

# AWS S3 (logo uploads, assets). R2/Spaces/MinIO: set AWS_S3_ENDPOINT and often AWS_REGION=auto.
# Plain AWS: set AWS_S3_BUCKET and keys; default region is us-east-1 if AWS_S3_ENDPOINT is unset.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
# AWS_S3_PUBLIC_URL=
# AWS_S3_ENDPOINT=
# Set to 1 if PutObject fails with AccessDenied on ACL (Block Public Access on bucket).
# AWS_S3_DISABLE_OBJECT_ACL=1

# Symmetric key for encrypting API keys and OAuth client id/secret on datasource rows (32 chars used).
# OAuth app credentials live in Mongo `datasources.oauthConfig` as encryptedClientId / encryptedClientSecret.
ENCRYPTION_KEY=roya-plus-default-32char-key-here

# Optional legacy redirect hints (callback URL is derived from API_BASE_URL + API_PREFIX in code).
# INSTAGRAM_REDIRECT_URI=https://roya-plus-api.roya.marketing/api/v1/auth/oauth/instagram/callback
# GOOGLE_REDIRECT_URI=https://roya-plus-api.roya.marketing/api/v1/auth/oauth/google/callback
