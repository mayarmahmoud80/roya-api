{
  "info": {
    "_postman_id": "38d8bee0-32f2-4910-973d-0763b44f954b",
    "name": "Roya Plus API",
    "description": "HTTP collection for the NestJS API (`website/royaai-plus-api`). Global prefix defaults to `/api/v1`. Import and set `baseUrl`, then run **Auth → Login** to fill `authToken`. Admin/owner JWT is required for builder-assets, report-types mutations, analysis-types mutations, and plans mutations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "authToken", "value": "" },
    { "key": "publicApiKey", "value": "" },
    { "key": "reportTypeId", "value": "" },
    { "key": "reportTypeSlug", "value": "brand-overview" },
    { "key": "builderAssetId", "value": "" },
    { "key": "analysisTypeId", "value": "" },
    { "key": "analysisId", "value": "" },
    { "key": "reportId", "value": "" },
    { "key": "integrationId", "value": "" },
    { "key": "apiKeyId", "value": "" },
    { "key": "invoiceId", "value": "" },
    { "key": "planId", "value": "" },
    { "key": "dataSourceId", "value": "" },
    { "key": "memberUserId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dev User\",\n  \"organizationName\": \"Dev Org\",\n  \"email\": \"dev@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.token) pm.collectionVariables.set('authToken', j.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dev@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Patch me",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated name\"\n}"
            },
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword123\"\n}"
            },
            "url": "{{baseUrl}}/auth/change-password"
          }
        }
      ]
    },
    {
      "name": "Report types (builder)",
      "item": [
        {
          "name": "List report types",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/report-types?page=1&limit=25"
          }
        },
        {
          "name": "Get report type by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/report-types/by-id/{{reportTypeId}}"
          }
        },
        {
          "name": "Get report type by slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/report-types/{{reportTypeSlug}}"
          }
        },
        {
          "name": "Create report type",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New report type\",\n  \"slug\": \"new-report-type\",\n  \"description\": \"Draft shell\",\n  \"scope\": \"global\"\n}"
            },
            "url": "{{baseUrl}}/report-types"
          }
        },
        {
          "name": "Update report type",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\"\n}"
            },
            "url": "{{baseUrl}}/report-types/{{reportTypeId}}"
          }
        },
        {
          "name": "Save draft version",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"defaultLanguage\": \"en\",\n  \"inputFields\": [],\n  \"dataSources\": [],\n  \"outputSections\": [],\n  \"aiMapping\": {\n    \"aiProviderAssetId\": \"{{builderAssetId}}\",\n    \"instructionName\": \"main\",\n    \"instruction\": \"Summarize inputs.\"\n  },\n  \"allowNoExternalData\": true\n}"
            },
            "description": "Replace `aiProviderAssetId` with a real `aiProvider` builder-asset id from your DB. Extend arrays using DTOs in `report-type-version.dto.ts`.",
            "url": "{{baseUrl}}/report-types/{{reportTypeId}}/draft"
          }
        },
        {
          "name": "Validate draft",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/report-types/{{reportTypeId}}/validate"
          }
        },
        {
          "name": "Publish",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/report-types/{{reportTypeId}}/publish"
          }
        },
        {
          "name": "Archive",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/report-types/{{reportTypeId}}/archive"
          }
        },
        {
          "name": "Preview draft",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"websiteUrl\": \"https://example.com\"\n}"
            },
            "description": "Body should match the report type input schema keys.",
            "url": "{{baseUrl}}/report-types/{{reportTypeId}}/preview"
          }
        }
      ]
    },
    {
      "name": "Builder assets",
      "item": [
