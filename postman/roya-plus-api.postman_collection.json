    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Stripe webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "<stripe-signature>", "description": "Raw body must match Stripe signing secret." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "description": "Normally called by Stripe; requires valid `stripe-signature` and raw payload per `StripeService.constructEvent`.",
            "url": "{{baseUrl}}/webhooks/stripe"
          }
        }
      ]
    }
