              "raw": "{\n  \"assetType\": \"schemaFieldType\",\n  \"slug\": \"short-text-sample\",\n  \"scope\": \"global\",\n  \"status\": \"active\",\n  \"name\": {\n    \"defaultLanguage\": \"en\",\n    \"values\": {\n      \"en\": \"Short text\",\n      \"ar\": \"نص قصير\"\n    }\n  },\n  \"description\": {\n    \"defaultLanguage\": \"en\",\n    \"values\": { \"en\": \"Single-line text\" }\n  }\n}"
            },
            "url": "{{baseUrl}}/builder-assets"
          }
        },
        {
          "name": "Update builder asset",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/builder-assets/{{builderAssetId}}"
          }
