    {
      "name": "API keys",
      "item": [
        {
          "name": "List API keys",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api-keys"
          }
        },
        {
          "name": "Create API key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  const k = j.rawKey || j.key;",
                  "  if (k) pm.collectionVariables.set('publicApiKey', k);",
                  "  if (j._id) pm.collectionVariables.set('apiKeyId', j._id);",
                  "  if (j.id) pm.collectionVariables.set('apiKeyId', j.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Standalone QA\",\n  \"reportTypeIds\": [\"{{reportTypeId}}\"],\n  \"rateLimit\": 60\n}"
            },
            "description": "Replace `reportTypeIds` with Mongo ids for standalone report types your key may call.",
            "url": "{{baseUrl}}/api-keys"
          }
        },
        {
          "name": "Revoke API key",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api-keys/{{apiKeyId}}"
          }
        }
      ]
    },
