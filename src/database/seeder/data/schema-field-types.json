  {
    "assetType": "schemaFieldType",
    "slug": "column_chart",
    "name": {
      "defaultLanguage": "en",
      "values": {
        "en": "Column Chart",
        "ar": "رسم بياني عمودي"
      }
    },
    "description": {
      "defaultLanguage": "en",
      "values": {
        "en": "Chart.js bar chart data format."
      }
    },
    "scope": "global",
    "status": "active",
    "metadata": {
      "category": "chart",
      "valueType": "object",
      "uiControl": "chart-builder",
      "jsonSchemaType": "object",
      "valueSchemas": {
        "acceptedFormats": [
          {
            "formatKey": "chartjs_bar",
            "description": "Chart.js bar chart data format",
            "jsonSchema": {
              "type": "object",
              "properties": {
                "labels": { "type": "array", "items": { "type": "string" } },
                "datasets": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "label": { "type": "string" },
                      "data": { "type": "array", "items": { "type": "number" } },
                      "backgroundColor": { "type": "string" }
                    },
                    "required": ["label", "data"]
                  }
                }
              },
              "required": ["labels", "datasets"]
            },
            "sample": {
              "labels": ["Q1", "Q2", "Q3", "Q4"],
              "datasets": [
                { "label": "Revenue", "data": [120, 190, 150, 220], "backgroundColor": "#2563eb" },
                { "label": "Expenses", "data": [80, 110, 95, 130], "backgroundColor": "#f97316" }
              ]
            },
            "priority": 100
          }
        ],
        "canonicalFormatKey": "chartjs_bar",
        "aiInstructionHint": "Return Chart.js bar data with labels array and datasets array containing {label, data[], backgroundColor?}"
      }
    }
  }
